{
  "name": "csds-app",
  "version": "1.0.0",
  "description": "CSDS - Deadline Submission System",
  "type": "module",
  "scripts": {
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "dev": "npm run server:dev & npm run client:dev",
